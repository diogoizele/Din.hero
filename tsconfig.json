{
  "extends": "@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@app/*": ["./src/app/*"],
      "@app": ["./src/app/index.ts"],
      "@core/*": ["./src/core/*"],
      "@core": ["./src/core/index.ts"],
      "@features/*": ["./src/features/*"],
      "@shared/*": ["./src/shared/*"]
    },
    "types": ["jest"]
  }
}
